# Frontend Environment Configuration

# API Base URL
NEXT_PUBLIC_API_URL=http://localhost:5000

# Application Name
NEXT_PUBLIC_APP_NAME=FinanceTracker

# Features
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_SOCKET_IO=true

# Google OAuth - Get from Google Console
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret

# NextAuth Configuration - Generate with: openssl rand -base64 32
# NEXTAUTH_URL=http://localhost:3000 (or your production domain)
# NEXTAUTH_SECRET=your_generated_secret

# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to GitHub
