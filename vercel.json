{
  "version": 2,
  "builds": [
    {
      "src": "backend/package.json",
      "use": "@vercel/node@2.15.0"
    },
    {
      "src": "frontend/next.config.js",
      "use": "@vercel/next@4.2.3",
      "config": {
        "maxLambdaSize": "15mb",
        "memory": 1024,
        "duration": 30
      }
    }
  ],
  "routes": [
    {
      "src": "/api/v1(.*)",
      "dest": "backend/src/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "frontend"
    }
  ],
  "outputDirectory": "frontend/.next"
}
